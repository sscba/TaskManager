    {
      "name": "2. Register New Unverified User",
      "item": [
        {
          "name": "Register - New User (triggers verification email)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var data = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', data.token);",
                  "    pm.collectionVariables.set('new_user_token', data.token);",
                  "    console.log('✅ Registered. emailVerified:', data.emailVerified);",
                  "    console.log('📧 Check inbox for verification email');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"newpass123\",\n  \"email\": \"{{new_user_email}}\",\n  \"fullName\": \"New Test User\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Update new_user_email variable to YOUR real Gmail before running. A verification email will arrive."
          },
          "response": []
        },
        {
          "name": "Try Login Before Verification (Should Fail 401)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"newpass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Expected 401 — email not verified yet"
          },
          "response": []
        }
      ]
    },
