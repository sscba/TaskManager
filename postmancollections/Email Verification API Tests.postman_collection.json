  "item": [
    {
      "name": "1. Login Pre-Verified Users",
      "item": [
        {
          "name": "Login as Admin (Pre-Verified)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.collectionVariables.set('jwt_token', pm.response.json().token);",
                  "    pm.collectionVariables.set('admin_token', pm.response.json().token);",
                  "    console.log('✅ Admin logged in. emailVerified:', pm.response.json().emailVerified);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Pre-verified user — login should succeed immediately"
          },
          "response": []
        },
        {
          "name": "Login as User (Pre-Verified)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
