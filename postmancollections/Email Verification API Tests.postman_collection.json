    {
      "name": "4. Verify Email (Manual Token Step)",
      "item": [
        {
          "name": "Verify Email - Using Token from Inbox",
          "event": [
            {
              "listen": "preRequest",
              "script": {
                "exec": [
                  "// IMPORTANT:",
                  "// 1. Open your Gmail inbox",
                  "// 2. Find the 'Verify Your Email' email",
                  "// 3. Copy the token from the link:",
                  "//    http://localhost:8083/api/auth/verify-email?token=COPY-THIS-PART",
                  "// 4. Paste into the 'verification_token' collection variable",
                  "console.log('📧 Paste your token into verification_token variable before sending!');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-email?token={{verification_token}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "verify-email"
              ],
              "query": [
                {
                  "key": "token",
                  "value": "{{verification_token}}"
                }
              ]
            },
            "description": "Paste token from email into the 'verification_token' collection variable first"
          },
          "response": []
        },
        {
          "name": "Check Status After Verification",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/verification-status?email={{new_user_email}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "verification-status"
              ],
              "query": [
                {
                  "key": "email",
                  "value": "{{new_user_email}}"
                }
              ]
            },
            "description": "Expected: success=true after verification"
          },
          "response": []
        },
        {
          "name": "Login After Verification (Should Succeed 200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    console.log('✅ Login successful after verification!');",
                  "    console.log('emailVerified:', pm.response.json().emailVerified);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"newpass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Expected 200 — email is now verified"
          },
          "response": []
        },
        {
          "name": "Logout user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
